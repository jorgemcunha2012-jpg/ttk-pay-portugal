# Copia para .env na raiz (não fazer commit do .env) ou define no painel do hosting.
TIKTOK_PIXEL_ID=D5S7LCJC77U7L31UJJEG
CLARITY_PROJECT_ID=udbympghov

# WayMB — API https://api.waymb.com (ver waymb-doc no GitHub)
WAYMB_CLIENT_ID=
WAYMB_CLIENT_SECRET=
# Email da conta WayMB (obrigatório em account_email)
WAYMB_ACCOUNT_EMAIL=
# URL pública do site (https://...) se o proxy enviar Host errado — callbackUrl, success_url, links do checkout
# WAYMB_PUBLIC_BASE_URL=https://teudominio.com
# Prefixo dos ficheiros de checkout (default /checkout)
# CHECKOUT_PATH_PREFIX=/checkout
# Página de sucesso após pagamento WayMB (path no mesmo origin)
# WAYMB_SUCCESS_PATH=/index.html

# UTMIFY (opcional) — sem isto, o checkout e o webhook ignoram notificações UTMIFY
# UTMIFY_TOKEN=
